{
    "kind": "collectionType",
    "collectionName": "products",
    "info": {
        "singularName": "product",
        "pluralName": "products",
        "displayName": "Product"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {
        "i18n": {
            "localized": true
        }
    },
    "attributes": {
        "title": {
            "type": "string",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "slug": {
            "type": "uid",
            "targetField": "title"
        },
        "price": {
            "type": "decimal",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "description": {
            "type": "text",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "isFeatured": {
            "type": "boolean",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            },
            "default": false
        },
        "spOne": {
            "type": "boolean",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            },
            "default": false
        },
        "spTwo": {
            "type": "boolean",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            },
            "default": false
        },
        "spThree": {
            "type": "boolean",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            },
            "default": false
        },
        "modelHeight": {
            "type": "string",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "modelWeight": {
            "type": "string",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "modelSize": {
            "type": "string",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            }
        },
        "image": {
            "type": "media",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            },
            "multiple": true,
            "allowedTypes": ["images", "files", "videos", "audios"]
        },
        "colorVariants": {
            "type": "component",
            "repeatable": true,
            "component": "product.color-variant"
        },
        "category": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::category.category",
            "inversedBy": "products"
        },
        "sizeXS": {
            "type": "boolean",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            },
            "default": false
        },
        "sizeS": {
            "type": "boolean",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            },
            "default": false
        },
        "sizeM": {
            "type": "boolean",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            },
            "default": false
        },
        "sizeL": {
            "type": "boolean",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            },
            "default": false
        },
        "sizeXL": {
            "type": "boolean",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            },
            "default": false
        },
        "sizeXXL": {
            "type": "boolean",
            "pluginOptions": {
                "i18n": {
                    "localized": true
                }
            },
            "default": false
        },
        "cart_items": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::cart-item.cart-item",
            "mappedBy": "product"
        },
        "likedByUsers": {
            "type": "relation",
            "relation": "manyToMany",
            "target": "api::userdb.userdb",
            "inversedBy": "likedProducts"
        }
    }
}
